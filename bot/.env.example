# NoneBot 基础配置
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=DEBUG

# 管理员 QQ 号列表，按实际情况修改
SUPERUSERS=["123456789"]

# 命令配置
COMMAND_START=["/", ""]
COMMAND_SEP=["."]

# OneBot / NapCat WebSocket 地址
ONEBOT_WS_URLS=["ws://127.0.0.1:3001"]

# Redis 与后端服务地址
REDIS_URL=redis://localhost:6379
API_BASE_URL=http://localhost:8000

# 预留的外部能力配置，默认留空
LLM_API_KEY=
BILI_COOKIE=
